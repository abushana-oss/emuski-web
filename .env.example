# Blogger API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
BLOGGER_API_KEY=your_blogger_api_key_here

# Blog IDs - Find these in Blogger Dashboard > Settings > Basic > Blog ID
MANUFACTURING_BLOG_ID=3331639473149657933
ENGINEERING_BLOG_ID=4682365218770663652
SUCCESS_STORIES_BLOG_ID=your_success_stories_blog_id

# Revalidation Secret (for webhook-based cache invalidation)
# Generate a random string for production: openssl rand -base64 32
REVALIDATE_SECRET=your_random_secret_here_change_in_production

# Optional: Legacy public variables (for client-side fallback)
NEXT_PUBLIC_BLOGGER_API_KEY=your_blogger_api_key_here
NEXT_PUBLIC_ENGINEERING_BLOG_ID=4682365218770663652
NEXT_PUBLIC_ENABLE_ENGINEERING_BLOG=true
